---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const projects = allWork.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Work — Suneel Armstrong">
  <main class="page">

    <a href="/" class="back-link">&larr; Back</a>

    <h1 class="page-title">Work</h1>
    <p class="page-sub">A selection of projects across creative direction, film, and technology.</p>

    <div class="work-list">
      {projects.map((project) => (
        <a href={`/work/${project.id}`} class="work-card">
          <div class="work-thumb">
            {project.data.thumbnail
              ? <img src={project.data.thumbnail} alt={project.data.title} />
              : <span class="ph-label">Image</span>
            }
          </div>
          <div class="work-info">
            <div>
              <span class="work-category">{project.data.category}</span>
              <h2 class="work-title">{project.data.title}</h2>
              <p class="work-desc">{project.data.description}</p>
            </div>
            <div class="work-links">
              {project.data.watchLink && (
                <a
                  href={project.data.watchLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-outline"
                  onclick="event.stopPropagation()"
                >Watch &rarr;</a>
              )}
              <span class="btn-outline">Deep Dive &rarr;</span>
            </div>
          </div>
        </a>
      ))}
    </div>

  </main>
</Layout>

<style>
  .page {
    max-width: 52rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  .back-link {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #C9503A;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 2.5rem;
    transition: opacity 0.15s;
  }
  .back-link:hover { opacity: 0.7; }

  .page-title {
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #1C1A17;
    margin: 0 0 0.5rem 0;
  }

  .page-sub {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.9rem;
    color: rgba(28, 26, 23, 0.55);
    margin: 0 0 3rem 0;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .work-card {
    display: flex;
    align-items: stretch;
    border: 1px solid rgba(28, 26, 23, 0.1);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    background: #fff;
    transition: border-color 0.18s, background 0.18s;
  }
  .work-card:hover { border-color: rgba(28, 26, 23, 0.2); background: #fafaf9; }

  .work-thumb {
    width: 280px;
    flex-shrink: 0;
    background: #E8E4DD;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .work-thumb img { width: 100%; height: 100%; object-fit: cover; }

  .ph-label {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(28, 26, 23, 0.25);
  }

  .work-info {
    flex: 1;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
  }

  .work-category {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #C9503A;
    display: block;
    margin-bottom: 0.4rem;
  }

  .work-title {
    font-family: 'Noto Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1C1A17;
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
  }

  .work-desc {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.85rem;
    color: rgba(28, 26, 23, 0.6);
    margin: 0;
    line-height: 1.6;
  }

  .work-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-outline {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #C9503A;
    border: 1.5px solid #C9503A;
    border-radius: 0;
    padding: 0.4rem 1rem;
    text-decoration: none;
    background: linear-gradient(to right, #C9503A 50%, transparent 50%);
    background-size: 200%;
    background-position: 100% 0;
    transition: background-position 0.35s ease, color 0.35s ease;
    cursor: pointer;
  }
  .btn-outline:hover {
    background-position: 0% 0;
    color: #fff;
  }

  @media (max-width: 600px) {
    .work-card { flex-direction: column; }
    .work-thumb { width: 100%; aspect-ratio: 16/9; }
  }
</style>
