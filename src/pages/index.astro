---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const projects = allWork.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Suneel Armstrong — Creative Director & Technologist">

  <main class="page">

    <!-- ======================================================
         HERO
    ====================================================== -->
    <section class="hero">
      <div class="hero-top">
        <h1 class="name">SUNEEL ARMSTRONG</h1>
        <p class="tagline">Creative Director &amp; Technologist</p>

        <p class="hero-intro">
          I make films and tell stories. Someone who is creative, pretty good at AI & technology and cares about the craft.
        </p>
      </div>

      <div class="hero-bottom">
        <div class="quests-block">
          <h2 class="quests-heading">Right now</h2>
          <ul class="quest-list">
            <li>&rarr; Making story-centered Ad-Films and Films, that doesn't smell like AI.</li>
            <li>&rarr; Launched a kick-ass tool for creators who struggle to <a href="https://be-articulate.xyz/" target="_blank" rel="noopener noreferrer" class="highlight-link">articulate</a>.</li>
            <li>&rarr; Building efficient workflows and systems to make the creative process repeatable and useful for myself and the team I work with.</li>
            <li>&rarr; Collecting aura points.</li>
          </ul>
        </div>

        <div class="quests-block">
          <h2 class="quests-heading">In the past</h2>
          <ul class="quest-list">
            <li>&rarr; Produced podcasts and content for real estate brands.</li>
            <li>&rarr; Built enterprise applications and automations for BOSCH.</li>
            <li>&rarr; Hosted hackathons in India, Japan.</li>
          </ul>
        </div>
      </div>

      <div class="hero-right">
        <!-- Video / Photo area -->
        <div class="video-frame">
          <!-- Fallback image shown until video loads -->
          <img
            src="https://res.cloudinary.com/de0frkjm7/image/upload/w_600,h_800,c_fill,g_face/v1773947883/designer_jteewz.jpg"
            alt="Suneel Armstrong"
            class="video-el hero-img"
            style="opacity:1"
          />
          <video
            id="loop-vid"
            src="https://res.cloudinary.com/de0frkjm7/video/upload/v1773947799/rest-suneel_ohxtgq.mp4"
            autoplay
            loop
            muted
            playsinline
            class="video-el"
            style="opacity:0"
          ></video>
          <video
            id="backflip-vid"
            src="https://res.cloudinary.com/de0frkjm7/video/upload/v1773947799/backflip-suneel_lalng5.mp4"
            muted
            playsinline
            preload="auto"
            class="video-el"
            style="opacity:0"
          ></video>
        </div>
        <div class="btn-wrap">
          <button id="backflip-btn" class="pill-btn">Backflip</button>
        </div>
      </div>
    </section>

    <!-- ======================================================
         FEATURED WORK
    ====================================================== -->
    <section class="section">
      <h2 class="section-title" style="margin-bottom: 1.75rem;">Featured Work</h2>

      <div class="work-list">
        {projects.map((project) => (
          <article class="work-card">
            {/* Cover link — no nested <a> */}
            <a href={`/work/${project.id}`} class="card-cover-link" aria-label={project.data.title}></a>

            {/* Layer 1: blurred ambient background — bleeds image colors across whole card */}
            {project.data.thumbnail && (
              <div
                class="card-ambient"
                style={`background-image: url('${project.data.thumbnail}')`}
              ></div>
            )}

            {/* Layer 2: sharp image, left side, fades right via mask */}
            <div class="card-img-wrap">
              {project.data.thumbnail
                ? <img src={project.data.thumbnail} alt={project.data.title} class="card-img" />
                : <div class="card-img-ph"></div>
              }
            </div>

            {/* Layer 3: glass content panel */}
            <div class="card-glass">
              <h3 class="card-title">{project.data.title}</h3>
              <p class="card-sub">{project.data.description}</p>
              {project.data.watchLink && (
                <a
                  href={project.data.watchLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="watch-btn"
                >
                  Watch Now
                </a>
              )}
            </div>
          </article>
        ))}
      </div>

      <div style="margin-top: 1.25rem; text-align: center;">
        <a href="/work" class="pill-outline">see more &rarr;</a>
      </div>
    </section>

    <!-- ======================================================
         I WRITE (Thoughts)
    ====================================================== -->
    <section class="section">
      <div class="section-head">
        <div>
          <h2 class="section-title">I write</h2>
          <p class="section-sub">Notes on creativity, technology, and making things.</p>
        </div>
      </div>

      <div class="writing-list">
        {[
          { title: 'How Claude helped my AI Ad Film. Reality | Step by Step', date: '18 Feb 2026', url: 'https://x.com/thesuneelvarma/status/2021800123773391199?s=20' },
          { title: 'Your Best Ideas Won\'t Go Viral as a New Creator, WHY??', date: '18 Jan 2026', url: 'https://x.com/thesuneelvarma/status/2012600451255148938?s=20' },
          { title: 'Sense of humor & Pizza', date: '15 Jan 2026', url: 'https://x.com/thesuneelvarma/status/2011714107423277183?s=20' },
        ].map((a) => (
          <a href={a.url} target="_blank" rel="noopener noreferrer" class="article-row">
            <span class="article-title">{a.title}</span>
            <span class="article-date">{a.date}</span>
          </a>
        ))}
      </div>

      <div class="show-more">
        <a href="/writing" class="muted-link">show all posts &darr;</a>
      </div>
    </section>

    <!-- ======================================================
         PROUD SIDE QUESTS
    ====================================================== -->
    <section class="section">
      <h2 class="section-title" style="margin-bottom:0.5rem;">Side Projects</h2>
      <p class="section-sub" style="margin-bottom:1.5rem;">
        Things I built, won, or showed up.
      </p>

      <div class="photo-scroll-wrap">
        <div class="photo-track" id="photo-track">
          {[
            { label: 'Hosted N8N Japan Hackathon', sub: 'Yokohama, 2025', img: '/images/events/JPNHCKTN.jpg' },
            { label: 'LeetCode Top 10%', sub: 'Globally', img: '/images/events/leetcode.jpg' },
            { label: 'I Stream', sub: 'Tech, Creativity & Films', img: '/images/events/livestream.jpg' },
            { label: 'IRL-maxxing', sub: '2025, 2026', img: '/images/events/events.JPG' },
          ].map((card) => (
            <div class="photo-card">
              <div class="photo-img">
                {card.img
                  ? <img src={card.img} alt={card.label} style="width:100%;height:100%;object-fit:cover;display:block;" />
                  : <span class="ph-label" style="color:rgba(255,255,255,0.4);">Photo</span>
                }
              </div>
              <div class="photo-caption">
                <span class="photo-label">{card.label}</span>
                <span class="photo-sub">{card.sub}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ======================================================
         SAY HI / FOOTER
    ====================================================== -->
    <section class="section">
      <div class="contact-box">
        <p class="contact-msg">
          Hey YOU!
        </p>
        <p class="contact-msg">
          I'm SUNEEL VARMA [aka SUNEEL ARMSTRONG]. I'm a polymath, I write code, I do graphic design, I do copywriting, I edit videos, I write film scripts &amp; I love to produce them myself.
        </p>
        <p class="contact-msg">
          I fell in love with filmmaking very early on, it took some time to figure out life, finances and what I care about. I produce videos/films myself, I aim to make films that bring my ideas and thoughts to reality. I believe in individualism, anyone can achieve anything they want to. I don't like to say I can't do it. If I'm not doing it, it's not interesting to me, that's all.
        </p>
        <p class="contact-msg">
          I read and survived [lol] books like The Fountainhead, Atlas Shrugged, and other work by Ayn Rand and Dostoyevsky's Crime and Punishment. I read a lot of technical stuff and watch films whenever I have some time to kill. I'd love to chat about them any day.
        </p>
        <p class="contact-msg"><strong>Just Say Hi!</strong></p>

        <div class="social-links">
          <a href="https://www.instagram.com/thesuneelvarma" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Instagram">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="https://www.x.com/thesuneelvarma" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="X">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.836L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.youtube.com/thesuneelvarma" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="YouTube">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
        <a href="https://calendly.com/suneelvarma55/articulate-enterprise" target="_blank" rel="noopener noreferrer" class="book-call-link">Book a call</a>
      </div>
    </section>

  </main>

</Layout>

<script>
  const btn = document.getElementById('backflip-btn') as HTMLButtonElement | null;
  const loopVid = document.getElementById('loop-vid') as HTMLVideoElement | null;
  const backflipVid = document.getElementById('backflip-vid') as HTMLVideoElement | null;
  const heroImg = document.querySelector('.hero-img') as HTMLImageElement | null;

  // Once loop video can play, hide fallback image and show video
  if (loopVid) {
    loopVid.addEventListener('canplay', () => {
      if (heroImg) heroImg.style.opacity = '0';
      loopVid.style.opacity = '1';
    }, { once: true });
  }

  // Infinite auto-scroll photo strip (GPU-accelerated via transform)
  const track = document.getElementById('photo-track') as HTMLElement | null;
  if (track) {
    // Clone all tiles for seamless loop
    const origItems = Array.from(track.children);
    origItems.forEach((item) => {
      const clone = item.cloneNode(true) as HTMLElement;
      clone.setAttribute('aria-hidden', 'true');
      track.appendChild(clone);
    });

    // Wait one frame for layout so scrollWidth is accurate
    requestAnimationFrame(() => {
      const halfWidth = track.scrollWidth / 2;
      let pos = 0;
      let paused = false;
      let isDragging = false;
      let dragStartX = 0;
      let dragStartPos = 0;
      let touchStartX = 0;
      let touchStartPos = 0;

      const tick = () => {
        if (!paused) {
          pos += 0.4;
          if (pos >= halfWidth) pos -= halfWidth;
          track.style.transform = `translateX(${-pos}px)`;
        }
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);

      const wrap = track.parentElement!;

      wrap.addEventListener('mouseenter', () => { paused = true; wrap.style.cursor = 'grab'; });
      wrap.addEventListener('mouseleave', () => { paused = false; isDragging = false; wrap.style.cursor = ''; });
      wrap.addEventListener('mousedown', (e) => {
        isDragging = true;
        dragStartX = e.pageX;
        dragStartPos = pos;
        wrap.style.cursor = 'grabbing';
      });
      window.addEventListener('mouseup', () => {
        if (isDragging) { isDragging = false; wrap.style.cursor = 'grab'; }
      });
      wrap.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        pos = (dragStartPos - (e.pageX - dragStartX) + halfWidth * 10) % halfWidth;
        track.style.transform = `translateX(${-pos}px)`;
      });

      wrap.addEventListener('touchstart', (e) => {
        paused = true;
        touchStartX = e.touches[0].pageX;
        touchStartPos = pos;
      }, { passive: true });
      wrap.addEventListener('touchmove', (e) => {
        pos = (touchStartPos - (e.touches[0].pageX - touchStartX) + halfWidth * 10) % halfWidth;
        track.style.transform = `translateX(${-pos}px)`;
      }, { passive: true });
      wrap.addEventListener('touchend', () => { paused = false; });
    });
  }

  if (btn && loopVid && backflipVid) {
    // Preload backflip video silently so it's ready instantly on click
    backflipVid.load();

    btn.addEventListener('click', async () => {
      btn.disabled = true;
      backflipVid.currentTime = 0;

      // Start backflip playing while loop is STILL fully visible
      try { await backflipVid.play(); } catch (_) {}

      // Fade backflip IN on top — loop stays at opacity:1 underneath the whole time
      // This means there is always 100% opaque video showing — no black frame ever
      backflipVid.style.opacity = '1';

      // Only pause loop AFTER the CSS transition finishes (300ms matches transition: opacity 0.3s)
      setTimeout(() => loopVid.pause(), 300);

      backflipVid.addEventListener('ended', () => {
        // Restart loop while backflip is still fully visible on top
        loopVid.play();
        loopVid.style.opacity = '1';
        // Only hide backflip after loop transition is done
        setTimeout(() => {
          backflipVid.style.opacity = '0';
          btn.disabled = false;
        }, 300);
      }, { once: true });
    });
  }
</script>

<style>
  /* ---- Base ---- */
  .page {
    max-width: 52rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  /* ---- Hero ---- */
  .hero {
    display: grid;
    grid-template-columns: 1fr 340px;
    grid-template-areas:
      "top   video"
      "bottom video";
    column-gap: 4rem;
    align-items: start;
    margin-bottom: 5rem;
  }

  .hero-top    { grid-area: top; }
  .hero-bottom { grid-area: bottom; }
  .hero-right  { grid-area: video; position: sticky; top: 2rem; }

  .name {
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(1.4rem, 3.2vw, 2.2rem);
    font-weight: 600;
    color: #1C1A17;
    margin: 0 0 0.35rem 0;
    line-height: 1;
    white-space: nowrap;
  }

  .tagline {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.91rem;
    color: #F4611A;
    margin: 0 0 1.5rem 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .hero-intro {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(28, 26, 23, 0.8);
    margin: 0 0 2rem 0;
  }

  .quests-block {
    margin-bottom: 1.5rem;
  }

  .quests-heading {
    font-family: 'Noto Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1C1A17;
    margin: 0 0 0.6rem 0;
  }

  .quest-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .quest-list li {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.875rem;
    color: rgba(28, 26, 23, 0.75);
    line-height: 1.55;
  }

  /* Video */

  .video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    background: #E8E4DD;
    border-radius: 12px;
    overflow: hidden;
  }

  .video-el {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: opacity 0.3s ease;
  }

  .video-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(28, 26, 23, 0.25);
  }

  .btn-wrap {
    margin-top: 0.75rem;
    text-align: center;
  }

  .pill-btn {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #F4611A;
    border: 1.5px solid #F4611A;
    background: linear-gradient(to right, #F4611A 50%, transparent 50%);
    background-size: 200%;
    background-position: 100% 0;
    padding: 0.5rem 1.75rem;
    border-radius: 0;
    cursor: pointer;
    transition: background-position 0.35s ease, color 0.35s ease;
  }
  .pill-btn:hover {
    background-position: 0% 0;
    color: #fff;
  }

  /* ---- Sections ---- */
  .section {
    margin-bottom: 4rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(28, 26, 23, 0.08);
  }

  .section-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
  }

  .section-title {
    font-family: 'Noto Sans', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #1C1A17;
    margin: 0;
    line-height: 1;
  }

  .section-sub {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.85rem;
    color: rgba(28, 26, 23, 0.55);
    margin: 0.4rem 0 0 0;
    line-height: 1.5;
  }

  .pill-outline {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #F4611A;
    border: 1.5px solid #F4611A;
    border-radius: 0;
    padding: 0.4rem 1.1rem;
    text-decoration: none;
    white-space: nowrap;
    background: linear-gradient(to right, #F4611A 50%, transparent 50%);
    background-size: 200%;
    background-position: 100% 0;
    transition: background-position 0.35s ease, color 0.35s ease;
    align-self: flex-start;
    margin-top: 0.1rem;
  }
  .pill-outline:hover {
    background-position: 0% 0;
    color: #fff;
  }

  /* ---- Work ---- */
  .work-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .work-card {
    position: relative;
    display: flex;
    align-items: stretch;
    height: 260px;
    border-radius: 16px;
    overflow: hidden;
    background: #111;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .work-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
  }

  /* Cover link */
  .card-cover-link {
    position: absolute;
    inset: 0;
    z-index: 3;
  }

  /* Layer 1: ambient blurred background */
  .card-ambient {
    position: absolute;
    inset: -20px;
    background-size: cover;
    background-position: center;
    filter: blur(32px) brightness(0.55) saturate(1.4);
    transform: scale(1.1);
    z-index: 0;
  }

  /* Layer 2: sharp image, left side */
  .card-img-wrap {
    position: relative;
    width: 45%;
    flex-shrink: 0;
    z-index: 1;
    /* mask fades image into glass on the right */
    -webkit-mask-image: linear-gradient(to right, black 55%, transparent 100%);
    mask-image: linear-gradient(to right, black 55%, transparent 100%);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .card-img-ph {
    width: 100%;
    height: 100%;
    background: rgba(255,255,255,0.05);
  }

  /* Layer 3: glass content panel */
  .card-glass {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
    padding: 2rem 2rem 2rem 1.5rem;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .card-category {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #F4611A;
  }

  .card-title {
    font-family: 'Noto Sans', sans-serif;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .card-sub {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    line-height: 1.6;
    max-width: 42ch;
  }

  .watch-btn {
    display: inline-block;
    margin-top: 0.5rem;
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.5);
    padding: 0.45rem 1.25rem;
    text-decoration: none;
    background: linear-gradient(to right, rgba(255,255,255,0.15) 50%, transparent 50%);
    background-size: 200%;
    background-position: 100% 0;
    transition: background-position 0.35s ease, border-color 0.35s ease;
    position: relative;
    z-index: 4;
    align-self: flex-start;
  }
  .watch-btn:hover {
    background-position: 0% 0;
    border-color: rgba(255,255,255,0.8);
  }

  @media (max-width: 600px) {
    .work-card { height: auto; flex-direction: column; }
    .card-img-wrap {
      width: 100%;
      height: 180px;
      -webkit-mask-image: linear-gradient(to bottom, black 55%, transparent 100%);
      mask-image: linear-gradient(to bottom, black 55%, transparent 100%);
    }
    .card-glass { border-left: none; border-top: 1px solid rgba(255,255,255,0.1); }
  }

  /* ---- Writing ---- */
  .writing-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(28, 26, 23, 0.06);
    text-decoration: none;
    transition: color 0.15s;
  }
