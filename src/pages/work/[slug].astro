---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

const { slug } = Astro.params;

const allWork = await getCollection('work');
const entry = allWork.find((e) => e.id === slug);

if (!entry) {
  return Astro.redirect('/');
}

const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} — Suneel Armstrong`} description={entry.data.description}>

  <div style="max-width: 64rem; margin: 0 auto; padding-left: 1.5rem; padding-right: 1.5rem; padding-top: 5rem; padding-bottom: 5rem;">

    <!-- Back link -->
    <a
      href="/"
      style="font-family: 'Noto Sans', sans-serif; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #F4611A; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 3rem;"
    >
      &larr; Back to work
    </a>

    <!-- Category tag -->
    <div style="margin-bottom: 1rem;">
      <span style="font-family: 'Noto Sans', sans-serif; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #F4611A; background-color: rgba(193, 123, 58, 0.1); padding: 0.25rem 0.75rem; border-radius: 2px;">
        {entry.data.category}
      </span>
    </div>

    <!-- Title -->
    <h1 style="font-family: 'Black Han Sans', sans-serif; font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 600; line-height: 1.05; color: #1C1A17; margin: 0 0 1.5rem 0;">
      {entry.data.title}
    </h1>

    <!-- Description -->
    <p style="font-family: 'Noto Sans', sans-serif; font-size: 1rem; color: rgba(28,26,23,0.65); margin: 0 0 3rem 0; line-height: 1.7; max-width: 42rem;">
      {entry.data.description}
    </p>

    <!-- Video embed -->
    {entry.data.watchLink && (() => {
      const url = entry.data.watchLink;
      const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/))([a-zA-Z0-9_-]{11})/);
      const videoId = match?.[1];
      return videoId ? (
        <div style="width: 100%; aspect-ratio: 16/9; margin-bottom: 4rem; border-radius: 2px; overflow: hidden;">
          <iframe
            src={`https://www.youtube.com/embed/${videoId}`}
            title={entry.data.title}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            style="width: 100%; height: 100%; border: none;"
          ></iframe>
        </div>
      ) : null;
    })()}

    <!-- Markdown content -->
    <div class="prose-content">
      <Content />
    </div>

  </div>

</Layout>

<style>
  /* Prose styling for markdown content */
  .prose-content {
    max-width: 42rem;
    font-family: 'Noto Sans', sans-serif;
    color: #1C1A17;
    line-height: 1.8;
    font-size: 0.95rem;
  }

  .prose-content :global(h2) {
    font-family: 'Black Han Sans', sans-serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: #1C1A17;
    margin: 2.5rem 0 1rem 0;
    line-height: 1.2;
  }

  .prose-content :global(h3) {
    font-family: 'Black Han Sans', sans-serif;
    font-size: 1.35rem;
    font-weight: 600;
    color: #1C1A17;
    margin: 2rem 0 0.75rem 0;
    line-height: 1.2;
  }

  .prose-content :global(p) {
    margin: 0 0 1.25rem 0;
    color: rgba(28, 26, 23, 0.8);
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem 0;
  }

  .prose-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose-content :global(a) {
    color: #F4611A;
    text-decoration: underline;
  }

  .prose-content :global(strong) {
    font-weight: 700;
    color: #1C1A17;
  }

  .prose-content :global(blockquote) {
    border-left: 3px solid #F4611A;
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    color: rgba(28, 26, 23, 0.6);
    font-style: italic;
    font-family: 'Black Han Sans', sans-serif;
    font-size: 1.1rem;
  }
</style>
