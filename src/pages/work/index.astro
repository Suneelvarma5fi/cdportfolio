---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const projects = allWork.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Work — Suneel Armstrong">
  <main class="page">

    <a href="/" class="back-link" onclick="event.preventDefault(); history.length > 1 ? history.back() : window.location.href='/'">&larr; Back</a>

    <h1 class="page-title">Work</h1>
    <p class="page-sub">A selection of projects across creative direction, film, and technology.</p>

    <div class="work-list">
      {projects.map((project, i) => (
        <article class="work-card" data-index={i}>
          {/* Cover button — triggers modal, no nested <a> */}
          <button class="card-cover-btn" aria-label={`Read more about ${project.data.title}`}></button>

          {/* Layer 1: ambient blurred bg */}
          {project.data.thumbnail && (
            <div class="card-ambient" style={`background-image: url('${project.data.thumbnail}')`}></div>
          )}

          {/* Layer 2: sharp image with mask fade */}
          <div class="card-img-wrap">
            {project.data.thumbnail
              ? <img src={project.data.thumbnail} alt={project.data.title} class="card-img" />
              : <div class="card-img-ph"></div>
            }
          </div>

          {/* Layer 3: glass content */}
          <div class="card-glass">
            <h2 class="card-title">{project.data.title}</h2>
            <p class="card-sub">{project.data.description}</p>
            <div class="card-actions">
              {project.data.watchLink && (
                <a
                  href={project.data.watchLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="watch-btn"
                >Watch</a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

  </main>

  {/* Modals */}
  {projects.map((project, i) => (
    <dialog id={`modal-${i}`} class="project-modal">
      <div class="modal-inner">
        <button class="modal-close" data-close={i}>&times;</button>
        <h2 class="modal-title">{project.data.title}</h2>
        <p class="modal-body">{project.data.longDescription ?? project.data.description}</p>
        <div class="modal-actions">
          {project.data.watchLink && (
            <a href={project.data.watchLink} target="_blank" rel="noopener noreferrer" class="watch-btn">Watch</a>
          )}
        </div>
      </div>
    </dialog>
  ))}
</Layout>

<script>
  document.querySelectorAll<HTMLElement>('.work-card').forEach((card) => {
    const idx = card.dataset.index!;
    const modal = document.getElementById(`modal-${idx}`) as HTMLDialogElement | null;
    const btn = card.querySelector('.card-cover-btn') as HTMLButtonElement | null;
    btn?.addEventListener('click', () => modal?.showModal());
  });

  document.querySelectorAll<HTMLButtonElement>('[data-close]').forEach((btn) => {
    const modal = document.getElementById(`modal-${btn.dataset.close}`) as HTMLDialogElement | null;
    btn.addEventListener('click', () => modal?.close());
  });

  document.querySelectorAll<HTMLDialogElement>('.project-modal').forEach((modal) => {
    modal.addEventListener('click', (e) => {
      const r = modal.getBoundingClientRect();
      if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) {
        modal.close();
      }
    });
  });
</script>

<style>
  .page {
    max-width: 52rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  .back-link {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F4611A;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 2.5rem;
    transition: opacity 0.15s;
  }
  .back-link:hover { opacity: 0.7; }

  .page-title {
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #1C1A17;
    margin: 0 0 0.5rem 0;
  }

  .page-sub {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.9rem;
    color: rgba(28, 26, 23, 0.55);
    margin: 0 0 3rem 0;
  }

  /* ---- Cards ---- */
  .work-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .work-card {
    position: relative;
    display: flex;
    align-items: stretch;
    height: 260px;
    border-radius: 16px;
    overflow: hidden;
    background: #111;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .work-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
  }

  .card-cover-btn {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: none;
    border: none;
    cursor: pointer;
  }

  .card-ambient {
    position: absolute;
    inset: -20px;
    background-size: cover;
    background-position: center;
    filter: blur(32px) brightness(0.55) saturate(1.4);
    transform: scale(1.1);
    z-index: 0;
  }

  .card-img-wrap {
    position: relative;
    width: 45%;
    flex-shrink: 0;
    z-index: 1;
    -webkit-mask-image: linear-gradient(to right, black 55%, transparent 100%);
    mask-image: linear-gradient(to right, black 55%, transparent 100%);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-img-ph {
    width: 100%;
    height: 100%;
    background: rgba(255,255,255,0.05);
  }

  .card-glass {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
    padding: 2rem 2rem 2rem 1.5rem;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .card-title {
    font-family: 'Noto Sans', sans-serif;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .card-sub {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    line-height: 1.6;
    max-width: 42ch;
  }

  .card-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    position: relative;
    z-index: 4;
  }

  .watch-btn {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.5);
    padding: 0.4rem 1rem;
    text-decoration: none;
    background: linear-gradient(to right, rgba(255,255,255,0.15) 50%, transparent 50%);
    background-size: 200%;
    background-position: 100% 0;
    transition: background-position 0.35s ease, border-color 0.35s ease;
    align-self: flex-start;
  }
  .watch-btn:hover { background-position: 0% 0; border-color: rgba(255,255,255,0.8); }

  .deep-btn {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F4611A;
    border: 1.5px solid #F4611A;
    padding: 0.4rem 1rem;
    text-decoration: none;
    background: linear-gradient(to right, #F4611A 50%, transparent 50%);
    background-size: 200%;
    background-position: 100% 0;
    transition: background-position 0.35s ease, color 0.35s ease;
    align-self: flex-start;
  }
  .deep-btn:hover { background-position: 0% 0; color: #fff; }

  /* ---- Modal ---- */
  .project-modal {
    border: none;
    border-radius: 16px;
    padding: 0;
    max-width: 520px;
    width: calc(100vw - 3rem);
    background: #fff;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
  }

  .project-modal::backdrop {
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(4px);
  }

  .modal-inner {
    padding: 2.5rem;
    position: relative;
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    font-size: 1.4rem;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(28, 26, 23, 0.35);
    line-height: 1;
    transition: color 0.15s;
  }
  .modal-close:hover { color: #1C1A17; }

  .modal-title {
    font-family: 'Noto Sans', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #1C1A17;
    margin: 0 0 1rem 0;
    line-height: 1.2;
    padding-right: 2rem;
  }

  .modal-body {
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.9rem;
    color: rgba(28, 26, 23, 0.7);
    line-height: 1.75;
    margin: 0 0 1.75rem 0;
  }

  .modal-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* Reuse .watch-btn in modal context — needs dark version */
  .modal-actions .watch-btn {
    color: #F4611A;
    border-color: #F4611A;
    background: linear-gradient(to right, #F4611A 50%, transparent 50%);
    background-size: 200%;
    background-position: 100% 0;
  }
  .modal-actions .watch-btn:hover { background-position: 0% 0; color: #fff; border-color: #F4611A; }

  /* ---- Responsive ---- */
  @media (max-width: 600px) {
    .work-card { height: auto; flex-direction: column; }
    .card-img-wrap {
      width: 100%;
      height: 180px;
      -webkit-mask-image: linear-gradient(to bottom, black 55%, transparent 100%);
      mask-image: linear-gradient(to bottom, black 55%, transparent 100%);
    }
    .card-glass { border-left: none; border-top: 1px solid rgba(255,255,255,0.1); }
  }
</style>
